[Unit]
Description=First-Boot SSH Key Provisioning Setup
Documentation=man:firstboot-ssh-setup(1)
DefaultDependencies=no
Before=getty@ttyAMA0.service
ConditionPathExists=!/home/medadmin/.ssh/authorized_keys

[Service]
Type=oneshot
ExecStart=/usr/bin/firstboot-ssh-setup
TimeoutStartSec=0
StandardInput=tty
StandardOutput=tty
StandardError=tty
TTYPath=/dev/ttyAMA0
RemainAfterExit=yes
ProtectSystem=no
ProtectHome=no

[Install]
WantedBy=multi-user.target
