# MedTech Device OS - Stage 1 Build Configuration

MACHINE = "qemuarm64"
DISTRO = "poky"

# Image type
IMAGE_FSTYPES = "ext4 tar.bz2"

# Build parallel settings
BB_NUMBER_THREADS = "4"
PARALLEL_MAKE = "-j 4"

# Package formats
PACKAGE_CLASSES = "package_ipk"

# Image features
IMAGE_FEATURES += "ssh-server-openssh"
EXTRA_IMAGE_FEATURES += "debug-tweaks"

# Systemd as init manager
DISTRO_FEATURES:append = " systemd"
VIRTUAL-RUNTIME_init_manager = "systemd"
VIRTUAL-RUNTIME_initscripts = ""

# Qt6 and display support
DISTRO_FEATURES:append = " opengl"
DISTRO_FEATURES:remove = "wayland x11"

# IPv4/IPv6 networking
DISTRO_FEATURES:append = " ipv4 ipv6"

# Downloads and sstate cache
DL_DIR = "${TOPDIR}/../downloads"
SSTATE_DIR = "${TOPDIR}/../sstate-cache"

# ============================================================
# SPDX / SBOM generation (Yocto native — kirkstone+)
# ============================================================
# create-spdx is shipped with Poky; no extra layer needed.
# It auto-generates an SPDX 2.2 document for every recipe and
# assembles a complete image-level SPDX JSON during do_rootfs.
# Output: tmp/deploy/images/qemuarm64/spdx/
# Standards: ISO/IEC 40110, NTIA Minimum Elements, SPDX 2.2
INHERIT += "create-spdx"

# Human-readable indented JSON output
SPDX_PRETTY = "1"

# Compress per-package SPDX archives with gzip
SPDX_ARCHIVE_COMPRESS = "gz"

# Include source code references in the SPDX document
SPDX_INCLUDE_SOURCES = "1"

# Output directory (under DEPLOY_DIR_IMAGE)
SPDX_DEPLOY_DIR = "${DEPLOY_DIR_IMAGE}/spdx"

# Additional base packages
IMAGE_INSTALL:append = " \
    python3 \
    python3-pip \
    openssh \
    curl \
    wget \
    nano \
    htop \
"

