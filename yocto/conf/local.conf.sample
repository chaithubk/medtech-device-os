# MedTech Device OS - Stage 1 Build Configuration

MACHINE = "qemuarm64"
DISTRO = "poky"

# Image type
IMAGE_FSTYPES = "ext4 tar.bz2"

# Build parallel settings
BB_NUMBER_THREADS = "4"
PARALLEL_MAKE = "-j 4"

# Package formats
PACKAGE_CLASSES = "package_ipk"

# Image features
IMAGE_FEATURES += "ssh-server-openssh"
EXTRA_IMAGE_FEATURES += "debug-tweaks"

# Systemd as init manager
DISTRO_FEATURES:append = " systemd"
VIRTUAL-RUNTIME_init_manager = "systemd"
VIRTUAL-RUNTIME_initscripts = ""

# Qt6 and display support
DISTRO_FEATURES:append = " opengl"
DISTRO_FEATURES:remove = "wayland x11"

# IPv4/IPv6 networking
DISTRO_FEATURES:append = " ipv4 ipv6"

# Downloads and sstate cache
DL_DIR = "${TOPDIR}/../downloads"
SSTATE_DIR = "${TOPDIR}/../sstate-cache"

# SBOM generation (requires Poky kirkstone built-in sbom class)
# Set INHERIT += "create-spdx" if using meta-security or an SPDX-based approach
INHERIT += "sbom"
SBOM_FORMAT = "json"

# Additional base packages
IMAGE_INSTALL:append = " \
    python3 \
    python3-pip \
    openssh \
    curl \
    wget \
    nano \
    htop \
"

